# ─── Database ───────────────────────────────────────────────
DATABASE_URL=postgresql://axiom_user:axiom_pass@localhost:5432/axiom

# ─── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Kafka ──────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092

# ─── JWT ────────────────────────────────────────────────────
JWT_SECRET_KEY=your_super_secret_jwt_key_here
JWT_REFRESH_SECRET=your_super_secret_refresh_key_here
JWT_EXPIRY=7d

# ─── AWS ────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_key
AWS_SECRET_ACCESS_KEY=your_secret
AWS_REGION=us-east-1
AWS_S3_BUCKET=axiom-resumes

# ─── AI / LLM (DeepSeek V4 Flash) ───────────────────────────
DEEPSEEK_API_KEY=your_deepseek_key
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
AI_SERVICE_SECRET=your_ai_service_secret

# ─── App ────────────────────────────────────────────────────
NODE_ENV=development
API_PORT=4000
AI_SERVICE_PORT=8000

# ─── Frontend (Next.js) ─────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000

# ─── CORS (FastAPI) ─────────────────────────────────────────
ALLOWED_ORIGINS=https://yourdomain.com,https://api.yourdomain.com

# ─── Kafka (disable for MVP) ────────────────────────────────
KAFKA_ENABLED=false

# ─── Email (Resend for MVP) ──────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=noreply@yourdomain.com

# ─── Job freshness ──────────────────────────────────────────
JOB_MAX_AGE_DAYS=90
JOB_STALE_TITLE_REJECT=true

# ─── Turborepo Remote Cache (optional) ──────────────────────
# TURBO_TOKEN=your_vercel_token
# TURBO_TEAM=your_team_slug
