# Copy to /opt/axiom/.env on your VPS and fill in real values.
# Never commit the real .env file.

# ── GHCR (GitHub Container Registry) ─────────────────────────
# e.g. ghcr.io/yourusername/axiom
GHCR_IMAGE_PREFIX=ghcr.io/your-github-username/axiom
IMAGE_TAG=latest

# ── Domains ──────────────────────────────────────────────────
FRONTEND_URL=https://axiom.saswat.app
API_PUBLIC_URL=https://api.axiom.saswat.app
NEXT_PUBLIC_API_URL=https://axiom.saswat.app/api
ACME_EMAIL=you@saswat.app

# ── Database ─────────────────────────────────────────────────
POSTGRES_USER=axiom_user
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=axiom
DATABASE_URL=postgresql://axiom_user:change_me_strong_password@postgres:5432/axiom

# ── Redis ────────────────────────────────────────────────────
REDIS_PASSWORD=change_me_redis_password
REDIS_URL=redis://:change_me_redis_password@redis:6379/0

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET_KEY=change_me_min_32_chars_random
JWT_REFRESH_SECRET=change_me_min_32_chars_random
JWT_EXPIRY=7d
AI_SERVICE_SECRET=change_me_ai_secret

# ── Email (Resend) ───────────────────────────────────────────
RESEND_API_KEY=re_xxxx
EMAIL_FROM=AXIOM <noreply@saswat.app>

# ── AWS S3 (resumes) ─────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=axiom-resumes-prod
# Leave empty for real AWS S3; set for MinIO dev only
S3_ENDPOINT=

# ── AI (DeepSeek) ────────────────────────────────────────────
DEEPSEEK_API_KEY=

# ── Razorpay (production keys) ───────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_PLAN_MONTHLY=
RAZORPAY_PLAN_QUARTERLY=
RAZORPAY_PLAN_ANNUAL=

# ── OAuth ────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
