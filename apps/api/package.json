{
  "name": "@axiom/api",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "nodemon",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1073.0",
    "@aws-sdk/s3-request-presigner": "^3.1073.0",
    "@axiom/database": "workspace:*",
    "@axiom/shared-types": "workspace:*",
    "axios": "^1.7.0",
    "bcryptjs": "^2.4.3",
    "bull": "^4.16.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "express-xss-sanitizer": "^2.0.2",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "kafkajs": "^2.2.4",
    "morgan": "^1.10.0",
    "multer": "^2.2.0",
    "redis": "^4.7.0",
    "uuid": "^10.0.0",
    "zod": "^3.23.0"
